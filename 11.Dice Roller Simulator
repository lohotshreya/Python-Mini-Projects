import random

def roll_dice():
    print("--- Dice Roll Simulator ---")
    while True:
        try:
            sides = int(input("How many sides on the die? (e.g., 6, 20): "))
            amount = int(input("How many dice to roll? "))
            
            print(f"\nRolling {amount}d{sides}...")
            results = [random.randint(1, sides) for _ in range(amount)]
            
            print(f"Results: {results}")
            print(f"Total: {sum(results)}")
        except ValueError:
            print("Please enter valid numbers.")

        if input("\nRoll again? (y/n): ").lower() != 'y':
            break

if __name__ == "__main__":
    roll_dice()
